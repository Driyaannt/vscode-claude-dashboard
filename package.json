{
  "name": "claude-usage",
  "displayName": "Claude Usage",
  "description": "Track your Claude API request limits, weekly usage, and reset times directly from the VS Code status bar.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:claudeUsageView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "claudeUsageView",
          "name": "Claude Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-usage.refreshData",
        "title": "Refresh Claude Usage"
      },
      {
        "command": "claude-usage.setCodexAuth",
        "title": "Set Codex Auth"
      },
      {
        "command": "claude-usage.clearCodexAuth",
        "title": "Clear Codex Auth"
      }
    ],
    "configuration": {
      "title": "Claude Usage",
      "properties": {
        "claudeUsage.identifier": {
          "type": "string",
          "default": "",
          "description": "Identifier untuk API endpoint (username/email)"
        },
        "claudeUsage.codexBearerToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token untuk Codex API (opsional; lebih aman pakai command Set Codex Auth)"
        },
        "claudeUsage.codexEndpoint": {
          "type": "string",
          "default": "https://chatgpt.com/backend-api/wham/usage",
          "description": "Endpoint untuk mengambil data Codex usage"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vsix": "npx @vscode/vsce package --no-rewrite-relative-links",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
